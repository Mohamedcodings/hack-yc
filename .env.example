OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1-mini
API_PORT=8787
DEMETER_DATA_MODE=auto
# Set both values to "demo" locally when you want to bypass Clerk.
# DEMETER_AUTH_MODE=demo
# VITE_DEMETER_AUTH_MODE=demo

# Optional: enable real Clerk authentication.
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
# CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
# CLERK_SECRET_KEY=sk_test_your-key-here

# Optional: enable Supabase authentication (Google, GitHub, email OAuth).
# Takes precedence over Clerk when set unless DEMETER_AUTH_MODE=demo.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-project-anon-key
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-project-anon-key

# Optional: enable real Sentinel Hub NDVI/NDMI per-field analytics.
# Create OAuth credentials from the Copernicus Data Space / Sentinel Hub dashboard.
# SH_CLIENT_ID=your-sentinel-hub-client-id
# SH_CLIENT_SECRET=your-sentinel-hub-client-secret
